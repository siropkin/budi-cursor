{
  "name": "budi",
  "displayName": "budi — AI Coding Cost Tracker",
  "description": "Live cost analytics for AI coding agents. See session cost, health, and spending trends right in the status bar.",
  "version": "1.0.0",
  "publisher": "siropkin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/siropkin/budi-cursor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "cost",
    "tokens",
    "claude",
    "cursor",
    "analytics"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "budi.openDashboard",
        "title": "Budi: Open Dashboard"
      },
      {
        "command": "budi.refreshStatus",
        "title": "Budi: Refresh Status"
      },
      {
        "command": "budi.selectSession",
        "title": "Budi: Select Session"
      },
      {
        "command": "budi.toggleHealthPanel",
        "title": "Budi: Open Session Health"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "budi",
          "title": "budi",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "budi": [
        {
          "type": "webview",
          "id": "budi.healthPanel",
          "name": "budi"
        }
      ]
    },
    "configuration": {
      "title": "budi",
      "properties": {
        "budi.pollingIntervalMs": {
          "type": "number",
          "default": 15000,
          "minimum": 3000,
          "description": "How often to refresh the status bar (in milliseconds)."
        },
        "budi.daemonUrl": {
          "type": "string",
          "default": "http://127.0.0.1:7878",
          "description": "Base URL for the budi daemon."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "package": "vsce package --no-dependencies -o cursor-budi.vsix",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"README.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"README.md\"",
    "test": "vitest run --exclude \"out/**\"",
    "test:watch": "vitest --exclude \"out/**\""
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
