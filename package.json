{
  "name": "budi",
  "displayName": "budi — AI Coding Cost Tracker",
  "description": "VS Code / Cursor status bar for budi. Shows your Cursor and Copilot Chat spend over the last 1d / 7d / 30d, mirroring the Claude Code statusline. If you don't have budi installed yet, the extension will guide you through the install.",
  "version": "1.4.1",
  "publisher": "siropkin",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/siropkin/budi-cursor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "cost",
    "tokens",
    "claude",
    "cursor",
    "vscode",
    "copilot",
    "copilot chat",
    "analytics"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "budi.openDashboard",
        "title": "Budi: Open Dashboard"
      },
      {
        "command": "budi.refreshStatus",
        "title": "Budi: Refresh Status"
      },
      {
        "command": "budi.showWelcome",
        "title": "Budi: Show Welcome / First-Run Setup"
      }
    ],
    "configuration": {
      "title": "budi",
      "properties": {
        "budi.pollingIntervalMs": {
          "type": "number",
          "default": 15000,
          "minimum": 3000,
          "description": "How often to refresh the status bar (in milliseconds)."
        },
        "budi.daemonUrl": {
          "type": "string",
          "default": "http://127.0.0.1:7878",
          "pattern": "^https?://(127\\.0\\.0\\.1|localhost|\\[::1\\])(:\\d+)?(/.*)?$",
          "patternErrorMessage": "budi.daemonUrl must point at a loopback host (127.0.0.1, localhost, or ::1). Non-loopback values are ignored at runtime.",
          "description": "Base URL for the budi daemon. Must be a loopback host (127.0.0.1, localhost, or ::1) — the daemon is local-only by design."
        },
        "budi.cloudEndpoint": {
          "type": "string",
          "default": "https://app.getbudi.dev",
          "description": "Cloud dashboard URL opened when the status bar item is clicked. Matches the Claude Code statusline click-through."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "package": "vsce package --no-dependencies -o cursor-budi.vsix",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"README.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"README.md\"",
    "test": "vitest run --exclude \"out/**\"",
    "test:watch": "vitest --exclude \"out/**\""
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
